// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────

enum Role {
  admin
  delegate
  player
  referee
}

enum RegistrationStatus {
  confirmed
  pending
  cancelled
  awaiting_payment
}

enum PaymentStatus {
  pending
  validated
  rejected
}

enum RegistrationMethod {
  self
  delegate
}

enum TournamentStatus {
  draft
  open
  in_progress
  finished
}

enum LicenseStatus {
  active
  inactive
}

enum LicenseType {
  fada
  fide
  feda
  online
}

enum NotificationType {
  tournament
  registration
  payment
  system
  result
}

enum NotificationStatus {
  pending
  sent
  failed
  skipped
}

enum EloSource {
  fide_api
  fada_api
  online_api
}

enum GameResult {
  white_wins
  black_wins
  draw
  bye
}

// ─── MODELOS ──────────────────────────────────────────────────────

model User {
  id             Int            @id @default(autoincrement())
  email          String         @unique
  password       String
  role           Role
  fullName       String
  phone          String?
  pushToken      String?
  avatarUrl      String?
  createdAt      DateTime       @default(now())

  player               Player?
  delegate             Delegate?
  sessions             MobileSession[]
  notifications        Notification[]
  gamesRegistered      Game[]           @relation("GameRegisteredBy")
  paymentsValidated    PaymentReceipt[] @relation("PaymentValidatedBy")
  registrationsMade    Registration[]   @relation("RegistrationRegisteredBy")
  notifyRequests       TournamentNotifyRequest[]
}

model Player {
  id                Int            @id @default(autoincrement())
  userId            Int            @unique
  birthDate         DateTime
  NIF               String         @unique
  fideId            String?
  federation        String?
  clubId            Int?
  eloId             Int            @unique
  joinedAt          DateTime       @default(now())
  leftAt            DateTime?
  lastLatitude      Float?
  lastLongitude     Float?
  lastLocationAt    DateTime?

  user              User           @relation(fields: [userId], references: [id])
  club              Club?          @relation("JugadoresClub", fields: [clubId], references: [id])
  elo               Elo            @relation(fields: [eloId], references: [id])
  registrations     Registration[]
  gamesAsWhite      Game[]         @relation("JugadorBlanco")
  gamesAsBlack      Game[]         @relation("JugadorNegro")
  gamesAsBye        Game[]         @relation("JugadorBye")
  eloHistory        EloHistory[]
  licenses          License[]
  tournamentResults TournamentResult[]
}

model Delegate {
  id      Int   @id @default(autoincrement())
  userId  Int   @unique
  clubId  Int

  user    User  @relation(fields: [userId], references: [id])
  club    Club  @relation("DelegadosClub", fields: [clubId], references: [id])
}

model Club {
  id             Int            @id @default(autoincrement())
  name           String
  CIF            String         @unique
  address        String
  phone          String
  email          String
  createdAt      DateTime       @default(now())
  logoUrl        String?
  shortCode      String         @unique
  planActivo     Boolean        @default(false)
  website        String?
  description    String?

  delegates      Delegate[]     @relation("DelegadosClub")
  players        Player[]       @relation("JugadoresClub")
  tournaments    Tournament[]
}

model Tournament {
  id                Int              @id @default(autoincrement())
  name              String
  organizerId       Int
  venue             String
  gpsLocation       String?
  startDate         DateTime
  endDate           DateTime
  format            String
  rounds            Int
  currentRound      Int              @default(0)
  timeControl       String
  mode              String    @default("classical")
  availableSlots    Int
  registrationFee   Float
  status            TournamentStatus @default(draft)
  description           String?
  eloEligible           Boolean          @default(false)
  requirements          Json
  latitude              Float?
  longitude             Float?
  notificationRadius    Int?
  geoNotificationActive Boolean          @default(false)

  organizer         Club             @relation(fields: [organizerId], references: [id])
  registrations     Registration[]
  games             Game[]
  results           TournamentResult[]
  notifyRequests    TournamentNotifyRequest[]
}

model Registration {
  id               Int                @id @default(autoincrement())
  playerId         Int
  tournamentId     Int
  registeredAt     DateTime           @default(now())
  status           RegistrationStatus @default(pending)
  paymentStatus    PaymentStatus      @default(pending)
  method           RegistrationMethod @default(self)
  registeredById   Int?

  player           Player             @relation(fields: [playerId], references: [id])
  tournament       Tournament         @relation(fields: [tournamentId], references: [id])
  paymentReceipt   PaymentReceipt?
  registeredBy     User?              @relation("RegistrationRegisteredBy", fields: [registeredById], references: [id])
}

model PaymentReceipt {
  id               Int            @id @default(autoincrement())
  registrationId   Int?           @unique
  licenseId        Int?
  amount           Float
  date             DateTime       @default(now())
  status           PaymentStatus  @default(pending)
  fileUrl          String
  validatedById    Int?
  validatedAt      DateTime?

  registration     Registration?  @relation(fields: [registrationId], references: [id])
  license          License?       @relation(fields: [licenseId], references: [id])
  validatedBy      User?          @relation("PaymentValidatedBy", fields: [validatedById], references: [id])
}

model Game {
  id                Int         @id @default(autoincrement())
  tournamentId      Int
  roundNumber       Int
  tableNumber       Int?
  isBye             Boolean     @default(false)
  whitePlayerId     Int?
  blackPlayerId     Int?
  byePlayerId       Int?
  result            GameResult?
  moves             String?
  notes             String?
  durationSeconds   Int?
  eloEligible       Boolean     @default(false)
  registeredById    Int?

  tournament        Tournament  @relation(fields: [tournamentId], references: [id])
  whitePlayer       Player?     @relation("JugadorBlanco", fields: [whitePlayerId], references: [id])
  blackPlayer       Player?     @relation("JugadorNegro", fields: [blackPlayerId], references: [id])
  byePlayer         Player?     @relation("JugadorBye", fields: [byePlayerId], references: [id])
  registeredBy      User?       @relation("GameRegisteredBy", fields: [registeredById], references: [id])
}

model EloHistory {
  id             Int       @id @default(autoincrement())
  playerId       Int
  source         EloSource
  period         String
  classical      Int?
  rapid          Int?
  blitz          Int?
  classicalGames Int?
  rapidGames     Int?
  blitzGames     Int?
  updatedAt      DateTime  @default(now())

  player         Player    @relation(fields: [playerId], references: [id])

  @@unique([playerId, source, period])
}

model License {
  id               Int            @id @default(autoincrement())
  playerId         Int
  licenseNumber    String         @unique
  type             LicenseType
  issuedAt         DateTime
  expiresAt        DateTime
  status           LicenseStatus  @default(active)

  player           Player         @relation(fields: [playerId], references: [id])
  paymentReceipts  PaymentReceipt[]

  @@index([expiresAt])
}

model MobileSession {
  id               Int       @id @default(autoincrement())
  userId           Int
  token            String    @unique
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  isActive         Boolean   @default(true)

  user             User      @relation(fields: [userId], references: [id])
}

model Elo {
  id                    Int     @id @default(autoincrement())
  fadaClassical         Int     @default(0)
  fadaRapid             Int     @default(0)
  fadaBlitz             Int     @default(0)
  fideClassical         Int     @default(0)
  fideRapid             Int     @default(0)
  fideBlitz             Int     @default(0)
  onlineClassical       Int     @default(0)
  onlineRapid           Int     @default(0)
  onlineBlitz           Int     @default(0)
  fideClassicalGames    Int     @default(0)
  fideRapidGames        Int     @default(0)
  fideBlitzGames        Int     @default(0)
  fadaClassicalGames    Int     @default(0)
  fadaRapidGames        Int     @default(0)
  fadaBlitzGames        Int     @default(0)
  onlineClassicalGames  Int     @default(0)
  onlineRapidGames      Int     @default(0)
  onlineBlitzGames      Int     @default(0)

  player                Player?
}

model TournamentResult {
  id                Int      @id @default(autoincrement())
  playerId          Int
  tournamentId      Int
  finalPosition     Int
  points            Float
  winsAsWhite       Int      @default(0)
  drawsAsWhite      Int      @default(0)
  lossesAsWhite     Int      @default(0)
  winsAsBlack       Int      @default(0)
  drawsAsBlack      Int      @default(0)
  lossesAsBlack     Int      @default(0)
  performanceRating Int?
  eloEligible       Boolean  @default(false)
  isFideRated       Boolean  @default(false)
  isFadaRated       Boolean  @default(false)
  eloChangeFide     Int?
  eloChangeFada     Int?
  eloChangeOnline   Int?

  player            Player     @relation(fields: [playerId], references: [id])
  tournament        Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([playerId, tournamentId])
}

model Notification {
  id             Int                  @id @default(autoincrement())
  userId         Int
  type           NotificationType
  status         NotificationStatus   @default(pending)
  title          String
  message        String
  dataJson       Json?
  isRead         Boolean              @default(false)
  createdAt      DateTime             @default(now())

  user           User                 @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
}

model TournamentNotifyRequest {
  id           Int        @id @default(autoincrement())
  userId       Int
  tournamentId Int
  createdAt    DateTime   @default(now())

  user         User       @relation(fields: [userId], references: [id])
  tournament   Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([userId, tournamentId])
}
