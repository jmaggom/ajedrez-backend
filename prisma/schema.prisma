// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────

enum Rol {
  admin
  delegado
  jugador
}

enum EstadoInscripcion {
  confirmada
  pendiente
  lista_espera
  cancelada
}

enum EstadoPago {
  pendiente
  validado
  rechazado
}

enum MetodoInscripcion {
  autonoma
  delegado
}

enum EstadoTorneo {
  borrador
  abierto
  en_curso
  finalizado
}

enum EstadoLicencia {
  activa
  inactiva
}

enum TipoNotificacion {
  torneo
  inscripcion
  pago
  sistema
}

// ─── MODELOS ──────────────────────────────────────────────────────

model Usuario {
  id               Int            @id @default(autoincrement())
  email            String         @unique
  password         String
  rol              Rol
  nombre_completo  String
  telefono         String?
  fecha_registro   DateTime       @default(now())
  club_id          Int?

  club             Club?          @relation("DelegadosClub", fields: [club_id], references: [id])
  jugador          Jugador?
  sesiones         SesionMovil[]
  notificaciones   Notificacion[]
}

model Jugador {
  id               Int            @id @default(autoincrement())
  usuario_id       Int            @unique
  fecha_nacimiento DateTime
  NIF              String         @unique
  licencia_numero  String?
  club_id          Int?
  elo_id           Int            @unique
  fecha_alta       DateTime       @default(now())
  fecha_baja       DateTime?
  federacion_id    String?

  usuario          Usuario        @relation(fields: [usuario_id], references: [id])
  club             Club?          @relation("JugadoresClub", fields: [club_id], references: [id])
  elo              Elo            @relation(fields: [elo_id], references: [id])
  inscripciones    Inscripcion[]
  partidas_blancas Partida[]      @relation("JugadorBlanco")
  partidas_negras  Partida[]      @relation("JugadorNegro")
  elo_historial    EloHistorial[]
  licencias        Licencia[]
}

model Club {
  id               Int            @id @default(autoincrement())
  nombre           String
  CIF              String         @unique
  direccion        String
  telefono         String
  email            String
  fecha_creacion   DateTime       @default(now())
  logo_url         String?
  codigo_corto     String         @unique

  delegados        Usuario[]      @relation("DelegadosClub")
  jugadores        Jugador[]      @relation("JugadoresClub")
  torneos          Torneo[]
}

model Torneo {
  id                  Int            @id @default(autoincrement())
  nombre              String
  organizador_id      Int
  sede                String
  ubicacion_gps       String?
  fecha_inicio        DateTime
  fecha_fin           DateTime
  modalidad           String
  num_rondas          Int
  ritmo_juego         String
  plazas_disponibles  Int
  tarifa_inscripcion  Float
  estado              EstadoTorneo   @default(borrador)
  descripcion         String?
  reglas_json         Json?

  organizador         Club           @relation(fields: [organizador_id], references: [id])
  inscripciones       Inscripcion[]
  partidas            Partida[]
  elo_historial       EloHistorial[]
}

model Inscripcion {
  id                Int                @id @default(autoincrement())
  jugador_id        Int
  torneo_id         Int
  fecha_inscripcion DateTime           @default(now())
  estado_inscripcion EstadoInscripcion @default(pendiente)
  estado_pago       EstadoPago         @default(pendiente)
  metodo            MetodoInscripcion  @default(autonoma)

  jugador           Jugador            @relation(fields: [jugador_id], references: [id])
  torneo            Torneo             @relation(fields: [torneo_id], references: [id])
  comprobante       ComprobantePago?
}

model ComprobantePago {
  id               Int            @id @default(autoincrement())
  inscripcion_id   Int?           @unique
  licencia_id      Int?
  monto            Float
  fecha            DateTime       @default(now())
  estado           EstadoPago     @default(pendiente)
  archivo_url      String

  inscripcion      Inscripcion?   @relation(fields: [inscripcion_id], references: [id])
  licencia         Licencia?      @relation(fields: [licencia_id], references: [id])
}

model Partida {
  id                  Int      @id @default(autoincrement())
  torneo_id           Int
  ronda_numero        Int
  jugador_blanco_id   Int
  jugador_negro_id    Int
  resultado           String
  movimientos         String?
  observaciones       String?
  duracion_segundos   Int?

  torneo              Torneo   @relation(fields: [torneo_id], references: [id])
  jugador_blanco      Jugador  @relation("JugadorBlanco", fields: [jugador_blanco_id], references: [id])
  jugador_negro       Jugador  @relation("JugadorNegro", fields: [jugador_negro_id], references: [id])
}

model EloHistorial {
  id                   Int       @id @default(autoincrement())
  jugador_id           Int
  elo_anterior_id      Int
  elo_nuevo_id         Int
  fecha_actualizacion  DateTime  @default(now())
  torneo_id            Int?

  jugador              Jugador   @relation(fields: [jugador_id], references: [id])
  elo_anterior         Elo       @relation("EloAnterior", fields: [elo_anterior_id], references: [id])
  elo_nuevo            Elo       @relation("EloNuevo", fields: [elo_nuevo_id], references: [id])
  torneo               Torneo?   @relation(fields: [torneo_id], references: [id])
}

model Licencia {
  id                Int            @id @default(autoincrement())
  jugador_id        Int
  numero_licencia   String         @unique
  fecha_emision     DateTime
  fecha_expiracion  DateTime
  estado            EstadoLicencia @default(activa)

  jugador           Jugador        @relation(fields: [jugador_id], references: [id])
  comprobantes      ComprobantePago[]
}

model SesionMovil {
  id               Int       @id @default(autoincrement())
  usuario_id       Int
  token            String    @unique
  fecha_creacion   DateTime  @default(now())
  fecha_expiracion DateTime
  activa           Boolean   @default(true)

  usuario          Usuario   @relation(fields: [usuario_id], references: [id])
}

model Elo {
  id                Int           @id @default(autoincrement())
  fada_clasicas     Int           @default(0)
  fada_rapidas      Int           @default(0)
  fada_blitz        Int           @default(0)
  fide_clasicas     Int           @default(0)
  fide_rapidas      Int           @default(0)
  fide_blitz        Int           @default(0)
  online_clasicas   Int           @default(0)
  online_rapidas    Int           @default(0)
  online_blitz      Int           @default(0)

  jugador                 Jugador?
  elo_historial_anterior  EloHistorial[] @relation("EloAnterior")
  elo_historial_nuevo     EloHistorial[] @relation("EloNuevo")
}

model Notificacion {
  id             Int               @id @default(autoincrement())
  usuario_id     Int
  tipo           TipoNotificacion
  titulo         String
  mensaje        String
  datos_json     Json?
  leida          Boolean           @default(false)
  fecha_creacion DateTime          @default(now())

  usuario        Usuario           @relation(fields: [usuario_id], references: [id])
}