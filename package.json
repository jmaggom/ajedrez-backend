{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "devDependencies": {
    "@types/bcryptjs": "3.0.0",
    "@types/cors": "2.8.19",
    "@types/express": "4",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/multer": "2.1.0",
    "@types/node": "25.5.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-mock-extended": "^4.0.0",
    "lint-staged": "^16.4.0",
    "nodemon": "3.1.14",
    "prisma": "5",
    "ts-jest": "^29.4.9",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "prepare": "husky",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration"
  },
  "dependencies": {
    "@apollo/server": "4",
    "@prisma/client": "5",
    "bcryptjs": "3.0.3",
    "cors": "2.8.6",
    "dotenv": "17.3.1",
    "expo-server-sdk": "^6.1.0",
    "express": "4",
    "graphql": "16.13.1",
    "jsonwebtoken": "9.0.3",
    "multer": "2.1.1"
  },
  "lint-staged": {
    "*.ts": [
      "tsc --noEmit",
      "eslint"
    ]
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma",
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} src/prisma/seed.ts"
  }
}
